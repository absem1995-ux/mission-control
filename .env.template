# Atlas — Multi-Platform Marketing Automation
# Copy this to .env and fill in your credentials

# ==========================================
# IMAGE GENERATION (REQUIRED)
# ==========================================
OPENAI_API_KEY=sk-...

# ==========================================
# POSTING SERVICE (REQUIRED)
# ==========================================
POSTIZ_API_KEY=...

# ==========================================
# PLATFORM APIs (REQUIRED FOR ENABLED PLATFORMS)
# ==========================================

# TikTok
TIKTOK_API_KEY=...
TIKTOK_API_SECRET=...

# Instagram / Facebook (Meta)
INSTAGRAM_ACCESS_TOKEN=...
FACEBOOK_ACCESS_TOKEN=...

# YouTube
YOUTUBE_API_KEY=...

# LinkedIn
LINKEDIN_ACCESS_TOKEN=...

# Reddit
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=...
REDDIT_PASSWORD=...

# ==========================================
# OPTIONAL (Phase 2+)
# ==========================================

# Voice-over generation (if voiceoverEnabled in config)
ELEVENLABS_API_KEY=...

# ==========================================
# RUNTIME OPTIONS
# ==========================================

# Set to 'true' to run all scripts in mock mode (no API calls)
MOCK_MODE=false

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Timezone for scheduling and reporting
TIMEZONE=UTC
