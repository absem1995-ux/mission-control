{
  "agent": {
    "name": "Astra",
    "role": "operations",
    "version": "1.0.0",
    "timezone": "UTC",
    "mockMode": true
  },
  "workHours": {
    "start": "08:00",
    "end": "18:00",
    "timezone": "UTC"
  },
  "taskLimits": {
    "maxConcurrent": 5,
    "maxPerDay": 50,
    "defaultTimeout": 300000
  },
  "workflows": {
    "scheduling": {
      "minSlotDuration": 30,
      "maxSchedulingTime": 300,
      "includeBuffer": true,
      "bufferMinutes": 15
    },
    "automation": {
      "parallelSteps": true,
      "retryAttempts": 3,
      "retryDelayMs": 5000
    },
    "delegation": {
      "requireApproval": true,
      "trackProgress": true,
      "reminderDays": [1, 3]
    }
  },
  "integrations": {
    "calendar": {
      "provider": "google_calendar",
      "mockMode": true,
      "apiKey": "${GOOGLE_CALENDAR_API_KEY}"
    },
    "taskTracker": {
      "provider": "linear",
      "mockMode": true,
      "apiKey": "${LINEAR_API_KEY}"
    },
    "email": {
      "provider": "sendgrid",
      "mockMode": true,
      "apiKey": "${SENDGRID_API_KEY}"
    }
  },
  "optimization": {
    "trackMetrics": true,
    "suggestImprovements": true,
    "performanceThreshold": 0.8
  },
  "escalation": {
    "successRateThreshold": 0.95,
    "failureCountThreshold": 3,
    "timeWindowMinutes": 1440
  }
}
